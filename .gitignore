# ==========================================
# Residual Cut Entropy — LaTeX .gitignore
# ==========================================

# LaTeX auxiliary files
*.aux
*.bbl
*.bcf
*.blg
*.fdb_latexmk
*.fls
*.fmt
*.lof
*.log
*.lot
*.out
*.run.xml
*.synctex.gz
*.toc
*.xdv

# Temporary build files
*.dvi
*.nav
*.snm
*.vrb
*.thm

# Backup/editor files
*.bak
*.backup
*.swp
*.tmp
*~

# OS files
.DS_Store
Thumbs.db

# Overleaf artifacts
latex.out/

# Keep the final compiled PDF tracked
!Paper.pdf

# Keep source files tracked
!paper.tex
!README.md
!LICENSE
!CITATION.cff
